# ── Copy this file to .env and fill in real values ───────────────────────────
# cp .env.example .env

# ── GEE / GCP ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=aranyai
GEE_SERVICE_ACCOUNT=aranyai-gee@aranyai.iam.gserviceaccount.com
GEE_KEY_FILE=gee-sa-key.json          # path to your downloaded JSON key
GCS_BUCKET=aranyai-exports-aranyai

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase Postgres — Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-string

# ── Mapbox (free at mapbox.com → Account → Tokens) ───────────────────────────
MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJleGFtcGxlIn0.REPLACE_THIS

# ── Frontend (Vite reads these at build time) ────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJleGFtcGxlIn0.REPLACE_THIS
