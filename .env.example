# ── Copy this file to .env and fill in real values ───────────────────────────
# cp .env.example .env

# ── GEE / GCP ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=aranyai
GEE_SERVICE_ACCOUNT=aranyai-gee@aranyai.iam.gserviceaccount.com
GEE_KEY_FILE=gee-sa-key.json          # path to your downloaded JSON key
GCS_BUCKET=aranyai-exports-aranyai

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local/Cloud Shell dev (zero setup):
DATABASE_URL=sqlite:///./aranyai.db
# PostgreSQL for production (Cloud SQL):
# DATABASE_URL=postgresql://user:password@/aranyai?host=/cloudsql/aranyai:asia-south1:aranyai-db

# ── Mapbox (free at mapbox.com → Account → Tokens) ───────────────────────────
MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJleGFtcGxlIn0.REPLACE_THIS

# ── Frontend (Vite reads these at build time) ────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJleGFtcGxlIn0.REPLACE_THIS
